# Copy to .dev.vars for local development (never committed).
#
# APP_ENV matters locally: without it the value from wrangler.toml ("production")
# applies, which both skips outbound email instead of no-opping it and sets
# Secure cookies over http://localhost, so sign-in silently fails.
APP_ENV=development
SETUP_KEY=local-dev-setup-key-123

# Leave RESEND_API_KEY unset locally: with APP_ENV=development the Worker logs
# emails instead of sending them, so no real freelancer can be contacted by accident.
# RESEND_API_KEY=re_xxx
